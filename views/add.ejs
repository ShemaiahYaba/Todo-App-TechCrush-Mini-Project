<%- include('partials/header') %>

<section class="hero-container">
  <div class="app-container form-page">
    <div class="top-menu">
      <div class="app-title">
        <h2><%= title %></h2>
      </div>
      <div class="app-btns">
        <a href="/" class="menu-btn">View Tasks</a>
      </div>
    </div>

    <div class="form-content show-form">
      <form action="/add" method="POST" class="task-form">
        <div class="form-row">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required maxlength="100" />
        </div>

        <div class="form-row">
          <label for="description">Description</label>
          <textarea id="description" name="description" required rows="4"></textarea>
        </div>

        <div class="form-row">
          <label for="priority">Priority</label>
          <select id="priority" name="priority">
            <option value="low"><%= helpers.capitalizeFirst('low') %></option>
            <option value="medium" selected><%= helpers.capitalizeFirst('medium') %></option>
            <option value="high"><%= helpers.capitalizeFirst('high') %></option>
          </select>
        </div>

        <div class="fm-btn">
          <button type="submit" class="submt">Add Task</button>
          <a href="/" class="cancl">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
