<%- include('partials/header') %>

<section class="hero-container">
  <div class="app-container form-page">
    <div class="top-menu">
      <div class="app-title">
        <h2><%= title %></h2>
      </div>
      <div class="app-btns">
        <a href="/" class="menu-btn">View Tasks</a>
      </div>
    </div>

    <div class="form-content show-form">
      <form action="/edit/<%= task.id %>" method="POST" class="task-form">
        <div class="form-row">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" value="<%= task.title %>" required maxlength="100" />
        </div>

        <div class="form-row">
          <label for="description">Description</label>
          <textarea id="description" name="description" required rows="4"><%= task.description %></textarea>
        </div>

        <div class="form-row">
          <label for="priority">Priority</label>
          <select id="priority" name="priority">
            <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>><%= helpers.capitalizeFirst('low') %></option>
            <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>><%= helpers.capitalizeFirst('medium') %></option>
            <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>><%= helpers.capitalizeFirst('high') %></option>
          </select>
        </div>

        <div class="form-row">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="pending" <%= task.status === 'pending' ? 'selected' : '' %>><%= helpers.capitalizeFirst('pending') %></option>
            <option value="completed" <%= task.status === 'completed' ? 'selected' : '' %>><%= helpers.capitalizeFirst('completed') %></option>
          </select>
        </div>

        <div class="fm-btn">
          <button type="submit" class="submt">Update Task</button>
          <a href="/" class="cancl">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
