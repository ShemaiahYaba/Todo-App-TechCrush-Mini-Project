<%- include('partials/header') %>

<section class="hero-container">
  <div class="app-container">
    <div class="top-menu">
      <div class="app-title">
        <h2><%= title %></h2>
      </div>
      <div class="app-btns">
        <a href="/add" class="menu-btn">Add Task</a>
        <a href="/" class="menu-btn">View Tasks</a>
      </div>
    </div>

    <div class="filter-section">
      <a href="/" class="filter-btn">All Tasks</a>
      <a href="/?status=pending" class="filter-btn">Pending</a>
      <a href="/?status=completed" class="filter-btn">Completed</a>
    </div>

    <% if (!tasks || tasks.length === 0) { %>
      <p class="no-tasks">No tasks found. <a href="/add">Add your first task</a>.</p>
    <% } else { %>
      <div class="table-header">
        <p>TASK</p>
        <p>STATUS</p>
        <p>PRIORITY</p>
        <p>ACTIONS</p>
      </div>

      <div class="task-list">
        <% tasks.forEach(task => { %>
          <article class="task-row">
            <div class="task-main">
              <h3><%= task.title %></h3>
              <p><%= task.description %></p>
              <small>Created: <%= new Date(task.createdAt).toLocaleDateString() %></small>
            </div>

            <div>
              <span class="badge status-<%= task.status %>"><%= task.status %></span>
            </div>

            <div>
              <span class="badge priority-<%= task.priority %>"><%= task.priority %></span>
            </div>

            <div class="task-actions">
              <a href="/edit/<%= task.id %>" class="action-btn">Edit</a>
              <a href="/toggle/<%= task.id %>" class="action-btn">
                <%= task.status === 'pending' ? 'Mark Complete' : 'Mark Pending' %>
              </a>
              <a
                href="/delete/<%= task.id %>"
                class="action-btn action-delete"
                onclick="return confirm('Are you sure you want to delete this task?')"
              >Delete</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
